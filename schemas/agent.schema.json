{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v-i-s-h-a-l.github.io/knowledge/schemas/agent.schema.json",
  "title": "Knowledge Garden Agent Brief Frontmatter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "id",
    "articleId",
    "slug",
    "title",
    "tokenBudget",
    "status",
    "updated"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^agent-brief:[a-z0-9-]+$"
    },
    "articleId": {
      "type": "string",
      "pattern": "^article:[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "tokenBudget": {
      "type": "integer",
      "minimum": 100
    },
    "status": {
      "enum": ["draft", "review", "published", "archived"]
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
