{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v-i-s-h-a-l.github.io/knowledge/schemas/article.schema.json",
  "title": "Knowledge Garden Article Frontmatter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "id",
    "slug",
    "title",
    "dek",
    "date",
    "updated",
    "status",
    "maturity",
    "topic",
    "tags",
    "summary",
    "readingTime",
    "agentArtifact",
    "sourcePath"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^article:[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "dek": {
      "type": "string",
      "minLength": 16,
      "maxLength": 220
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "status": {
      "enum": ["draft", "review", "published", "archived"]
    },
    "maturity": {
      "enum": ["seed", "sprout", "evergreen", "contested", "superseded"]
    },
    "topic": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 280
    },
    "readingTime": {
      "type": "string",
      "pattern": "^[0-9]+ min$"
    },
    "agentArtifact": {
      "type": "string",
      "pattern": "^/agents/articles/[a-z0-9-]+\\.json$"
    },
    "sourcePath": {
      "type": "string",
      "pattern": "^content/articles/\\d{4}/[a-z0-9-]+/article\\.md$"
    }
  }
}
