{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v-i-s-h-a-l.github.io/knowledge/schemas/artifact.schema.json",
  "title": "Knowledge Garden Agent Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "id",
    "slug",
    "title",
    "canonicalPath",
    "sourcePath",
    "agentBriefPath",
    "thesis",
    "status",
    "maturity",
    "publishedAt",
    "updatedAt",
    "audiences",
    "topics",
    "claims",
    "sources",
    "related",
    "agentInstructions",
    "humanReview",
    "contentHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^article:[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "canonicalPath": {
      "type": "string",
      "pattern": "^/articles/[a-z0-9-]+/$"
    },
    "sourcePath": {
      "type": "string",
      "pattern": "^content/articles/\\d{4}/[a-z0-9-]+/article\\.md$"
    },
    "agentBriefPath": {
      "type": "string",
      "pattern": "^content/articles/\\d{4}/[a-z0-9-]+/agent\\.md$"
    },
    "thesis": {
      "type": "string",
      "minLength": 80
    },
    "status": {
      "enum": ["draft", "review", "published", "archived"]
    },
    "maturity": {
      "enum": ["seed", "sprout", "evergreen", "contested", "superseded"]
    },
    "publishedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "audiences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "claim", "confidence", "status", "evidence", "counterevidence"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^claim-[0-9]{3}$"
          },
          "claim": {
            "type": "string",
            "minLength": 24
          },
          "confidence": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "counterevidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "url", "type", "accessed"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^source-[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 4
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "type": {
            "type": "string"
          },
          "accessed": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    },
    "related": {
      "type": "array"
    },
    "agentInstructions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "humanReview": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "reviewedAt", "reviewers", "notes"],
      "properties": {
        "status": {
          "type": "string"
        },
        "reviewedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
