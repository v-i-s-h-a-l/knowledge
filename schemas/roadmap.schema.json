{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://v-i-s-h-a-l.github.io/knowledge/schemas/roadmap.schema.json",
  "title": "Knowledge Garden Roadmap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "slug",
    "title",
    "summary",
    "status",
    "updatedAt",
    "sourceRepo",
    "thesis",
    "priorityCounts",
    "phases",
    "ideas",
    "principles",
    "crossAgentReview",
    "agentInstructions"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^roadmap:[a-z0-9-]+$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 360 },
    "status": { "type": "string", "enum": ["draft", "review", "published", "archived"] },
    "updatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "sourceRepo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "commit", "commitDate", "reviewedAt"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
        "commitDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reviewedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "thesis": { "type": "string", "minLength": 1 },
    "priorityCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["P0", "P1", "P2"],
      "properties": {
        "P0": { "type": "integer", "minimum": 0 },
        "P1": { "type": "integer", "minimum": 0 },
        "P2": { "type": "integer", "minimum": 0 }
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "horizon", "outcome", "ideaIds"],
        "properties": {
          "id": { "type": "string", "pattern": "^phase-[0-9]+$" },
          "name": { "type": "string", "minLength": 1 },
          "horizon": { "type": "string", "minLength": 1 },
          "outcome": { "type": "string", "minLength": 1 },
          "ideaIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^idea-[a-z0-9-]+$" },
            "uniqueItems": true
          }
        }
      }
    },
    "ideas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "priority",
          "category",
          "sourcePaths",
          "pattern",
          "gardenMapping",
          "firstImplementation",
          "risks"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^idea-[a-z0-9-]+$" },
          "title": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "category": {
            "type": "string",
            "enum": ["evidence", "governance", "authoring", "retrieval", "interface", "optimization"]
          },
          "sourcePaths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "pattern": { "type": "string", "minLength": 1 },
          "gardenMapping": { "type": "string", "minLength": 1 },
          "firstImplementation": { "type": "string", "minLength": 1 },
          "risks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "principles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "crossAgentReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewedAt", "reviewers", "notes"],
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reviewers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "agentInstructions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
