#!/usr/bin/env bash
set -euo pipefail

branch="$(git branch --show-current)"
identity_hook="${GIT_IDENTITY_HOOK:-"$HOME/.githooks/identity-current"}"

if [[ -x "$identity_hook" ]]; then
  "$identity_hook"
fi

if [[ "$branch" == "main" || "$branch" == "master" ]]; then
  echo "Direct commits to $branch are blocked. Use a feature branch/worktree and PR merge." >&2
  exit 1
fi

npm run check
npm audit --audit-level=moderate

if ! git diff --quiet -- content public package-lock.json; then
  echo "Generated files changed during checks. Review, stage, and commit them." >&2
  git status --short
  exit 1
fi
