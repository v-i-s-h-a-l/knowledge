---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Knowledge Garden"
  description="A focused AI-era knowledge garden for human-readable essays and agent-auditable research artifacts."
>
  <div class="page-shell">
    <section class="home-hero" aria-labelledby="home-title">
      <div>
        <p class="eyebrow">AI-era publishing</p>
        <h1 id="home-title">Readable by humans. Auditable by agents.</h1>
        <p class="lede">
          This garden treats the article as one rendering of a deeper research object: claim map,
          evidence ledger, source trail, revision history, and compact agent brief.
        </p>
        <div class="button-row" aria-label="Primary actions">
          <a class="button primary" href={`${base}articles/agent-auditable-research/`}>
            Read the first article
          </a>
          <a class="button" href={`${base}agents/`}>Open agent entry</a>
          <a class="button" href={`${base}graph/`}>Browse the graph</a>
        </div>
      </div>

      <aside class="stem-panel" aria-label="Knowledge stem preview">
        <div class="stem-node">
          <div>
            <strong>Root idea</strong>
            <span>Publishing shifts from polished prose to inspectable reasoning.</span>
          </div>
        </div>
        <div class="stem-node">
          <div>
            <strong>First article</strong>
            <span>The future is not AI-written content; it is agent-auditable research.</span>
          </div>
        </div>
        <div class="stem-node">
          <div>
            <strong>Next branches</strong>
            <span>Claim graphs, source ledgers, personal research workflows, and agent feeds.</span>
          </div>
        </div>
      </aside>
    </section>

    <section class="section-band section-grid" aria-labelledby="shape-title">
      <div>
        <p class="eyebrow">Publishing shape</p>
        <h2 id="shape-title">The garden is not a feed.</h2>
      </div>
      <div>
        <p>
          A feed rewards recency. This site rewards return visits to an evolving idea. Articles are
          designed as focused paths through one argument, then connected through topic stems and
          machine-readable artifacts.
        </p>
        <ul class="signal-list">
          <li>Humans get a calm reading sequence with impact blocks and visible provenance.</li>
          <li>Agents get structured metadata, claim IDs, source IDs, and compact index files.</li>
          <li>Future posts inherit the same validation, graph, and publication workflow.</li>
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
